{
  "name": "autonomous-engineer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aes": "./cli/index.ts"
  },
  "scripts": {
    "aes": "bun run ./cli/index.ts",
    "aes:dev": "bun --watch ./cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "build": "bun build ./cli/index.ts --outdir dist --target bun"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "ajv": "^8.17",
    "citty": "^0.2.1",
    "js-tiktoken": "^1.0.16",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "dprint": "^0.52.0"
  }
}
