{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": [
    "cli/**/*",
    "application/**/*",
    "domain/**/*",
    "adapters/**/*",
    "infra/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "docs"
  ]
}
